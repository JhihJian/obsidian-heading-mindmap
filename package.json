{
  "name": "obsidian-heading-mindmap",
  "version": "0.1.1",
  "description": "Open Markdown headings as editable mind maps and edit section content in a bottom pane.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "npm run build && node scripts/deploy-plugin.mjs",
    "install:local": "npm run build && node scripts/install-local.mjs",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "test": "vitest run",
    "test:e2e:obsidian": "node scripts/verify-obsidian-e2e.mjs",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "mindmap",
    "heading",
    "outline"
  ],
  "engines": {
    "node": ">=22"
  },
  "author": "JhihJian",
  "license": "MIT",
  "dependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^20.19.0",
    "@vitest/eslint-plugin": "^1.6.23",
    "esbuild": "^0.25.5",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.3"
  }
}
