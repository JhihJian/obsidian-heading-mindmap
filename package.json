{
  "name": "obsidian-heading-mindmap",
  "version": "0.1.0",
  "description": "Open Markdown headings as editable mind maps and edit section content in a bottom pane.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "npm run build && node scripts/deploy-plugin.mjs",
    "install:local": "npm run build && node scripts/install-local.mjs",
    "test": "vitest run",
    "test:e2e:obsidian": "node scripts/verify-obsidian-e2e.mjs",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "mindmap",
    "heading",
    "outline"
  ],
  "engines": {
    "node": ">=22"
  },
  "author": "JhihJian",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
